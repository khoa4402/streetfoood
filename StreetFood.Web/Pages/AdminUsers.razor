@page "/admin-users"
@using StreetFood.Web.Models
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary">Quản lý Tài khoản Chủ quán</h2>
        <button class="btn btn-primary shadow-sm" @onclick="OpenAddModal">
            <i class="oi oi-plus"></i> Thêm chủ quán mới
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">STT</th>
                        <th>Tên đăng nhập</th>
                        <th>Họ tên</th>
                        <th>Mã OwnerId</th>
                        <th>Vai trò</th>
                    </tr>
                </thead>
                <tbody>
                    @if (users == null)
                    {
                        <tr><td colspan="5" class="text-center py-4">Đang tải dữ liệu...</td></tr>
                    }
                    else if (users.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có tài khoản nào.</td></tr>
                    }
                    else
                    {
                        int stt = 1;
                        foreach (var u in users)
                        {
                            <tr>
                                <td class="ps-3">@(stt++)</td>
                                <td class="fw-bold">@u.Username</td>
                                <td>@u.FullName</td>
                                <td><span class="badge bg-success">@u.OwnerId</span></td>
                                <td><span class="badge bg-secondary">@u.Role</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(2px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Tạo tài khoản mới</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên đăng nhập:</label>
                        <input class="form-control form-control-lg" @bind="newUser.Username" placeholder="Ví dụ: chuquan3" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu:</label>
                        <input class="form-control form-control-lg" type="password" @bind="newUser.Password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ tên chủ quán:</label>
                        <input class="form-control form-control-lg" @bind="newUser.FullName" placeholder="Nhập tên đầy đủ" />
                    </div>
                    <div class="alert alert-warning d-flex align-items-center mb-0">
                        <div>
                            <strong>Lưu ý:</strong> Hệ thống sẽ tự động gán mã <b>OwnerId</b> (ví dụ: owner_03) dựa trên dữ liệu cũ.
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-outline-secondary" @onclick="CloseModal">Hủy</button>
                    <button class="btn btn-success px-4" @onclick="SaveUser">Lưu tài khoản</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<UserModel> users;
    private UserModel newUser = new();
    private bool showModal = false;
    
    // ĐÃ SỬA: Dùng đúng cổng 7117 của API mà bạn đã kiểm tra
    private string apiBaseUrl = "https://localhost:7117/api/User";

    protected override async Task OnInitializedAsync() => await LoadUsers();

    private async Task LoadUsers()
    {
        try
        {
            users = await Http.GetFromJsonAsync<List<UserModel>>(apiBaseUrl);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Lỗi tải danh sách: " + ex.Message);
        }
    }

    private void OpenAddModal()
    {
        newUser = new UserModel { Role = "ShopOwner" };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveUser()
    {
        try
        {
            // Gửi yêu cầu POST tới API
            var response = await Http.PostAsJsonAsync(apiBaseUrl, newUser);
            
            if (response.IsSuccessStatusCode)
            {
                await LoadUsers(); // Tải lại bảng để thấy User mới
                CloseModal();
                await JS.InvokeVoidAsync("alert", "Tạo tài khoản thành công!");
            }
            else
            {
                // Lấy chi tiết lỗi từ API nếu có (Ví dụ lỗi trùng tên, lỗi DB)
                var errorMsg = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", "Lỗi từ Server: " + errorMsg);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Không thể kết nối đến API. Hãy chắc chắn Project API đang chạy!");
            Console.WriteLine(ex.Message);
        }
    }
}